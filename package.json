{
  "name": "codex-bridge-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "A reliable local session layer for Claude or Codex to orchestrate long-lived Codex App Server tasks.",
  "type": "module",
  "bin": {
    "codex-bridge-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-static-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/daemon.ts",
    "start": "node dist/daemon.js",
    "start:stdio": "node dist/index.js",
    "generate:codex-types": "codex app-server generate-ts --experimental --out src/codex/generated && node scripts/fix-generated-imports.mjs",
    "check:forbidden": "node scripts/check-forbidden-runtime-spawns.mjs",
    "smoke:protocol": "tsx scripts/smoke-app-server-client.ts",
    "smoke:context": "tsx scripts/smoke-context-governance.ts",
    "smoke:queue": "tsx scripts/smoke-queue-recovery.ts",
    "smoke:recovery": "tsx scripts/smoke-recovery.ts",
    "smoke:runtime-interruption": "tsx scripts/smoke-runtime-interruption.ts",
    "smoke:tui-process-tree": "tsx scripts/smoke-tui-process-tree.ts",
    "smoke:project-session": "tsx scripts/smoke-project-session.ts",
    "smoke:attention": "tsx scripts/smoke-attention-delivery.ts",
    "smoke:diff": "tsx scripts/smoke-diff-service.ts",
    "smoke:mcp:http": "tsx scripts/smoke-mcp-http.ts",
    "smoke:mcp:stdio": "tsx scripts/smoke-mcp-stdio.ts",
    "smoke:mcp": "npm run smoke:mcp:http && npm run smoke:mcp:stdio",
    "demo:claude": "tsx scripts/demo-claude-via-mcp.ts",
    "e2e:real": "tsx scripts/e2e-real-runtime.ts"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "better-sqlite3": "^11.10.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
